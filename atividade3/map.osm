 <node id="13359160601" visible="true" version="2" changeset="175646020" timestamp="2025-12-08T02:32:03Z" user="Anonymous897234" uid="16885157" lat="35.6611952" lon="139.6971382">
  <tag k="amenity" v="restaurant"/>
  <tag k="branch" v="Shibuya"/>
  <tag k="contact:facebook" v="https://facebook.com/p/Andhra-Dining-Shibuya-100067132418649"/>
  <tag k="contact:instagram" v="andhra_dining"/>
  <tag k="contact:tablelog" v="https://tabelog.com/en/tokyo/A1303/A130301/13258029"/>
  <tag k="cuisine" v="indian;andhra_pradesh;andhra;south_indian"/>
  <tag k="description" v="South Indian restaurant specializing in authentic Andhra Pradesh cuisine, featuring dosas, vadas, spicy curries, biryanis, and thalis in Shibuya, Tokyo."/>
  <tag k="description:en" v="South Indian restaurant specializing in authentic Andhra Pradesh cuisine, featuring dosas, vadas, spicy curries, biryanis, and thalis in Shibuya, Tokyo."/>
  <tag k="description:es" v="Restaurante del sur de la India especializado en auténtica cocina de Andhra Pradesh, que ofrece dosas, vadas, curris picantes, biryanis y thalis en Shibuya, Tokio."/>
  <tag k="description:hi" v="टोक्यो के शिबुया में असली आंध्र प्रदेश व्यंजनों के लिए प्रसिद्ध साउथ इंडियन रेस्टोरेंट, जिसमें डोसा, वड़ा, मसालेदार करी, बिरयानी और थाली शामिल हैं।"/>
  <tag k="description:ja" v="東京渋谷で本格的なアンドラプラデーシュ料理を専門とする南インド料理店。ドーサ、ワダ、スパイシーなカレー、ビリヤニ、ターリを提供。"/>
  <tag k="description:ko" v="도쿄 시부야에 위치한 정통 안드라프라데시 요리를 전문으로 하는 남인도 레스토랑. 도사, 바다, 매운 카레, 비리야니, 탈리를 제공합니다."/>
  <tag k="description:te" v="టోక్యో శిబుయాలో ప్రధానాంగా అంధ్ర ప్రదేశ్ వంటకాలతో దోస, వడలు, మసాలా కర్రీలు, బిర్యానీ, తాళి లును అందించే దక్షిణ భారతీయ రెస్టారెంట్."/>
  <tag k="description:zh" v="位于东京涩谷，专营正宗安得拉邦南印度菜，特色菜品包括多萨饼、炸豆饼、辛辣咖喱、香饭和套餐。"/>
  <tag k="diet:halal" v="yes"/>
  <tag k="diet:non-vegetarian" v="yes"/>
  <tag k="diet:vegan" v="yes"/>
  <tag k="diet:vegetarian" v="yes"/>
