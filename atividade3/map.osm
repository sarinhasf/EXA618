  <tag k="addr:province" v="東京都"/>
  <tag k="alt_name:en" v="Tasu Ichi"/>
  <tag k="alt_name:ja" v="tatsuichi"/>
  <tag k="amenity" v="bar"/>
  <tag k="contact:email" v="info@tasuichi.co.jp"/>
  <tag k="contact:instagram" v="tasuichi.shibuya"/>
  <tag k="contact:retty" v="https://retty.me/area/PRE13/ARE8/SUB802/100000727742"/>
  <tag k="contact:tripadvisor" v="https://tripadvisor.com/Restaurant_Review-g1066456-d1659392-Reviews-Tasuichi-Shibuya_Tokyo_Tokyo_Prefecture_Kanto.html"/>
  <tag k="contact:webcam" v="http://shibuyatasu1.miemasu.net/CgiStart?page=Single&amp;Language=0"/>
  <tag k="contact:webcam:ja" v="http://shibuyatasu1.miemasu.net/CgiStart?page=Single&amp;Language=1"/>
  <tag k="contact:yelp" v="https://yelp.com/biz/tasu-ichi-%E6%B8%8B%E8%B0%B7%E5%8C%BA"/>
  <tag k="description" v="この活気ある立ち飲みバーは渋谷で観光客に人気があり、賑やかな雰囲気と手頃な価格のドリンクが特徴です。訪れる人々が地元の人々や他の旅行者と交流できるユニークな体験を提供し、社交に最適な歓迎的な環境を作り出しています。フレンドリーなスタッフが体験をさらに向上させ、誰もが渋谷のエネルギッシュなナイトライフを楽しみながら居心地の良さを感じられるようにしています。観光の後にリラックスしたり、新しい人々と出会ったりする場所を探しているなら、このバーは素晴らしい目的地です。"/>
  <tag k="description:en" v="This lively standing bar in Shibuya is a favorite among tourists, featuring a friendly atmosphere and affordable drinks. With its welcoming staff and vibrant nightlife, it attracts a diverse crowd of locals and international visitors."/>
  <tag k="description:ja" v="この活気ある立ち飲みバーは渋谷で観光客に人気があり、賑やかな雰囲気と手頃な価格のドリンクが特徴です。訪れる人々が地元の人々や他の旅行者と交流できるユニークな体験を提供し、社交に最適な歓迎的な環境を作り出しています。フレンドリーなスタッフが体験をさらに向上させ、誰もが渋谷のエネルギッシュなナイトライフを楽しみながら居心地の良さを感じられるようにしています。観光の後にリラックスしたり、新しい人々と出会ったりする場所を探しているなら、このバーは素晴らしい目的地です。"/>
  <tag k="name" v="TASUICHI"/>
  <tag k="name:en" v="TASUICHI"/>
